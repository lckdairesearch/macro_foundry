POSTGRES_PASSWORD=change_me
MACRODB_OWNER_URL=postgresql+psycopg://macrodb_owner:change_me@localhost:5432/macrodb_dev
MACRODB_APP_URL=postgresql+psycopg://macrodb_app:change_me@localhost:5432/macrodb_dev
MACRODB_TEST_URL=postgresql+psycopg://macrodb_app:change_me@localhost:5432/macrodb_test
MACRODB_STAGING_URL=postgresql+psycopg://macrodb_app:change_me@your-neon-host/macrodb_staging
MACRODB_API_BEARER_TOKEN=change_me
MACRODB_ADMIN_USERNAME=admin
MACRODB_ADMIN_PASSWORD=change_me
MACRODB_ADMIN_SESSION_SECRET=change_me
MACRODB_LOG_LEVEL=INFO

# --- Data provider keys ---
ALPHA_VANTAGE_API_KEY=your_key
FRED_API_KEY=your_key

# --- LLM providers (configure whichever you use) ---

# Plain OpenAI
OPENAI_API_KEY=your_key

# Azure OpenAI (set all four if using any AZURE_OPENAI-bound role)
AZURE_OPENAI_API_KEY=your_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Deployment names as configured in your Azure portal.
# DEPLOYMENT_DEFAULT maps to the standard model (e.g. gpt-4o).
# DEPLOYMENT_DEEP maps to the reasoning/thinking model (e.g. o3).
AZURE_OPENAI_DEPLOYMENT_DEFAULT=your-default-deployment
AZURE_OPENAI_DEPLOYMENT_DEEP=your-deep-deployment
